# =============================================================================
# Kimi Code - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual API keys and configuration.
# NEVER commit .env files to version control!
#
# Security Best Practices:
# - Keep API keys secret and rotate them regularly
# - Use environment-specific values
# - Never hardcode credentials in source code
# - Use a secrets manager for production deployments
# =============================================================================

# =============================================================================
# KIMI / MOONSHOT AI API
# =============================================================================
# Primary API for Kimi Code
# Get your API key from: https://platform.moonshot.ai/
KIMI_API_KEY=your_kimi_api_key_here

# Optional: Custom base URL for self-hosted or proxy endpoints
# KIMI_BASE_URL=https://api.moonshot.ai/v1

# Optional: Organization ID for enterprise accounts
# KIMI_ORG_ID=your_org_id

# =============================================================================
# OPENAI API (Optional - for fallback or comparison)
# =============================================================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Custom base URL for Azure OpenAI or proxies
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Organization ID
# OPENAI_ORG_ID=your_org_id

# =============================================================================
# ANTHROPIC API (Optional - for Claude models)
# =============================================================================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: API version
# ANTHROPIC_API_VERSION=2023-06-01

# =============================================================================
# GOOGLE GEMINI API (Optional)
# =============================================================================
# Get your API key from: https://ai.google.dev/
GOOGLE_API_KEY=your_google_api_key_here

# Optional: Custom endpoint
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com

# =============================================================================
# GITHUB INTEGRATION
# =============================================================================
# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Required scopes: repo, workflow, read:org, gist
GITHUB_TOKEN=your_github_token_here

# Optional: GitHub Enterprise Server URL
# GITHUB_ENTERPRISE_URL=https://github.yourcompany.com/api/v3

# Optional: GitHub App credentials (for advanced integrations)
# GITHUB_APP_ID=your_app_id
# GITHUB_APP_PRIVATE_KEY=path/to/private-key.pem
# GITHUB_APP_INSTALLATION_ID=your_installation_id

# =============================================================================
# GITLAB INTEGRATION (Optional)
# =============================================================================
# GitLab Personal Access Token
# Create at: https://gitlab.com/-/profile/personal_access_tokens
GITLAB_TOKEN=your_gitlab_token_here

# Optional: Self-hosted GitLab URL
# GITLAB_URL=https://gitlab.yourcompany.com

# =============================================================================
# DATABASE CONNECTIONS
# =============================================================================
# PostgreSQL
# Format: postgresql://user:password@host:port/database
POSTGRES_URL=postgresql://user:password@localhost:5432/kimi_code

# MySQL
# Format: mysql://user:password@host:port/database
MYSQL_URL=mysql://user:password@localhost:3306/kimi_code

# MongoDB
# Format: mongodb://user:password@host:port/database
MONGODB_URL=mongodb://user:password@localhost:27017/kimi_code

# Redis (for caching and sessions)
# Format: redis://user:password@host:port
REDIS_URL=redis://localhost:6379

# SQLite (for local development)
SQLITE_URL=sqlite:///./kimi_code.db

# =============================================================================
# CLOUD STORAGE
# =============================================================================
# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Optional: S3-compatible storage (MinIO, Wasabi, etc.)
# AWS_S3_ENDPOINT=https://s3-compatible-endpoint.com

# Google Cloud Storage
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_KEY_FILE=path/to/service-account-key.json
GOOGLE_CLOUD_STORAGE_BUCKET=your-bucket-name

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT=your-storage-account
AZURE_STORAGE_KEY=your-storage-key
AZURE_STORAGE_CONTAINER=your-container-name

# =============================================================================
# SEARCH API KEYS
# =============================================================================
# Google Custom Search API
# Get from: https://developers.google.com/custom-search/v1/overview
GOOGLE_SEARCH_API_KEY=your_google_search_api_key
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id

# Bing Search API
# Get from: https://www.microsoft.com/en-us/bing/apis/bing-web-search-api
BING_SEARCH_API_KEY=your_bing_api_key

# SerpAPI (for various search engines)
# Get from: https://serpapi.com/
SERPAPI_KEY=your_serpapi_key

# =============================================================================
# BROWSER AUTOMATION
# =============================================================================
# Browserless.io (for cloud browser automation)
BROWSERLESS_TOKEN=your_browserless_token

# Playwright settings
PLAYWRIGHT_BROWSERS_PATH=0

# Selenium Grid (for distributed browser automation)
# SELENIUM_GRID_URL=http://localhost:4444/wd/hub

# =============================================================================
# MONITORING & ANALYTICS
# =============================================================================
# Sentry (for error tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development

# Datadog (for metrics)
DATADOG_API_KEY=your_datadog_api_key
DATADOG_APP_KEY=your_datadog_app_key

# =============================================================================
# NOTIFICATION SERVICES
# =============================================================================
# Slack Webhook
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook/url

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@kimicode.dev

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Node environment: development, production, test
NODE_ENV=development

# Application port
PORT=3000

# Host binding
HOST=localhost

# Debug mode (set to 'true' for verbose logging)
DEBUG=false

# Hot reload for development
HOT_RELOAD=true

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
# JWT Secret (generate a strong random string)
JWT_SECRET=your_jwt_secret_here_min_32_characters_long

# Encryption key for sensitive data (32 characters for AES-256)
ENCRYPTION_KEY=your_32_character_encryption_key

# API rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=900

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable experimental features
ENABLE_EXPERIMENTAL=false

# Enable beta tools
ENABLE_BETA_TOOLS=false

# Enable debug mode for tools
TOOL_DEBUG_MODE=false

# =============================================================================
# EXTERNAL SERVICE INTEGRATIONS
# =============================================================================
# Jira
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your_jira_api_token

# Linear
LINEAR_API_KEY=your_linear_api_key

# Trello
TRELLO_API_KEY=your_trello_key
TRELLO_TOKEN=your_trello_token

# Notion
NOTION_TOKEN=your_notion_integration_token

# Confluence
CONFLUENCE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_EMAIL=your-email@example.com
CONFLUENCE_API_TOKEN=your_confluence_token

# =============================================================================
# MODEL-SPECIFIC SETTINGS
# =============================================================================
# Hugging Face (for model hosting)
HUGGINGFACE_TOKEN=your_hf_token

# Replicate (for AI model inference)
REPLICATE_API_TOKEN=your_replicate_token

# Together AI
TOGETHER_API_KEY=your_together_api_key

# Cohere
COHERE_API_KEY=your_cohere_api_key

# =============================================================================
# LOCAL AI / SELF-HOSTED MODELS
# =============================================================================
# Ollama (local LLM server)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# LM Studio
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# LocalAI
LOCALAI_BASE_URL=http://localhost:8080/v1

# =============================================================================
# TESTING SETTINGS
# =============================================================================
# Test database URL
TEST_DATABASE_URL=sqlite:///./test.db

# Mock external APIs in tests
MOCK_EXTERNAL_APIS=true

# Test timeout (ms)
TEST_TIMEOUT=30000

# =============================================================================
# DEPLOYMENT SETTINGS
# =============================================================================
# Docker registry
DOCKER_REGISTRY=your-registry.com
DOCKER_USERNAME=your_username
DOCKER_PASSWORD=your_password

# Kubernetes
KUBECONFIG_PATH=~/.kube/config

# Terraform
TF_VAR_environment=development
